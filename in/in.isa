proc fib(n: int) -> int {
    let a = 0;
    let b = 1;

    let i = 0;
    while i < n {
        let tmp = a + b;
        a = b;
        b = tmp;
        i = i + 1;
    }

    return a;
}

proc add(a: int) -> proc(int) -> int {
    proc add_a(b: int) -> int {
        return a + b;
    }

    return add_a;
}
